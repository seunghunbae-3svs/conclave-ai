    "@conclave-ai/agent-grok": "workspace:*",
    "@conclave-ai/agent-ollama": "workspace:*",
    "@conclave-ai/agent-openai": "workspace:*",
    "@conclave-ai/core": "workspace:*",
    "@conclave-ai/integration-discord": "workspace:*",
    "@conclave-ai/integration-email": "workspace:*",
    "@conclave-ai/integration-slack": "workspace:*",
    "@conclave-ai/integration-telegram": "workspace:*",
    "@conclave-ai/observability-langfuse": "workspace:*",
